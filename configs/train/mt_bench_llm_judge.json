{
    "provider_models": [
        ["openai", "gpt-5-nano-2025-08-07"],
        ["google", "gemini-3.1-flash-lite-preview"],
        ["anthropic", "claude-haiku-4-5-20251001"]
    ],
    "model_kwargs": [
        {"reasoning_effort": "low"},
        {},
        {}
    ],
    "model_costs_per_1m_input": [0.05, 0.25, 1.0],
    "model_costs_per_1m_output": [0.40, 1.5, 5.0],
    "model_concurrency": [10, 10, 10],

    "dataset": "HuggingFaceH4/mt_bench_prompts",
    "dataset_split": "train",
    "train_size": 160,
    "test_size": 40,

    "eval_mode": "llm_judge",
    "judge_config": {
        "provider": "openai",
        "model_name": "gpt-5-nano-2025-08-07"
    },
    "system_prompt": "Answer the question thoroughly and accurately.",

    "K_quality": 1.0,
    "K_latency": 0.5,
    "K_cost": 0.3,
    "latency_range": [500, 10000],
    "cost_range": [0.0, 0.005],

    "total_timesteps": 512,
    "rollout_steps": 64,
    "eval_interval": 64,
    "batch_size": 32,

    "seed": 42
}
