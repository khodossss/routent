{
    "provider_models": [
        ["openai", "gpt-5-nano-2025-08-07"],
        ["hf_classifier", "distilbert-base-uncased-finetuned-sst-2-english"]
    ],
    "model_kwargs": [
        {"reasoning_effort": "minimal"},
        {"label_map": {"0": "negative", "1": "positive"}}
    ],
    "model_costs_per_1m_input": [0.05, 0.0],
    "model_costs_per_1m_output": [0.40, 0.0],
    "model_concurrency": [10, 1],

    "dataset": "stanfordnlp/sst2",
    "dataset_split": "train",
    "train_size": 256,
    "test_size": 64,

    "eval_mode": "classification",
    "system_prompt": "Classify sentiment as 'positive' or 'negative'. Answer with only one word.",

    "K_quality": 1.0,
    "K_latency": 0.5,
    "K_cost": 0.5,
    "latency_range": [50, 3000],
    "cost_range": [0.0, 0.001],

    "total_timesteps": 1024,
    "rollout_steps": 128,
    "eval_interval": 128,
    "batch_size": 64,

    "seed": 42
}
