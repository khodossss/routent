{
    "provider_models": [
        ["openai", "gpt-5-nano-2025-08-07"],
        ["openai", "gpt-5-nano-2025-08-07"]
    ],
    "model_kwargs": [
        {"reasoning_effort": "minimal"},
        {"reasoning_effort": "low"}
    ],
    "model_costs_per_1m_input": [0.05, 0.05],
    "model_costs_per_1m_output": [0.40, 0.40],
    "model_concurrency": [10, 10],

    "dataset": "openai/gsm8k",
    "dataset_split": "train",
    "train_size": 64,
    "test_size": 16,

    "eval_config": {"mode": "numeric"},

    "K_quality": 1.0,
    "K_latency": 0.2,
    "K_cost": 0.2,
    "latency_range": [100, 10000],
    "cost_range": [0.0, 0.001],

    "total_timesteps": 128,
    "rollout_steps": 64,
    "eval_interval": 64,

    "seed": 42
}
